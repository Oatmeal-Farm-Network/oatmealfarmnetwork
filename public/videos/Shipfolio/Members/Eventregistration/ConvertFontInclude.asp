<% if tempfont = "Arial" then
  tempfont = "Arial, Helvetica, sans-serif"
end if 

if tempfont = "Palatino Linotype" then
  tempfont = "'Palatino Linotype', 'Book Antiqua', Palatino, serif"
end if 

